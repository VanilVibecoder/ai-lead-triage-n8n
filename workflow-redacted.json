    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\n\nconst leadName = String(body.name || 'Не указано').trim();\nconst leadMessage = String(body.message || '').trim();\nconst source = String(body.source || 'unknown').trim();\n\nconst rawPhone = String(body.phone || '').trim();\nconst rawEmail = String(body.email || '').trim().toLowerCase();\n\n// Нормализация телефона\nlet leadPhone = rawPhone\n  .replace(/[^\\d+]/g, '');\n\nif (/^8\\d{10}$/.test(leadPhone)) {\n  leadPhone = `+7${leadPhone.slice(1)}`;\n} else if (/^7\\d{10}$/.test(leadPhone)) {\n  leadPhone = `+${leadPhone}`;\n}\n\n// Валидация телефона\nconst isPhoneValid = /^\\+\\d{10,15}$/.test(leadPhone);\n\n// Валидация email\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst isEmailValid = rawEmail ? emailRegex.test(rawEmail) : false;\n\nconst leadEmail = isEmailValid ? rawEmail : '';\n\nconst hasMessage = leadMessage.length > 0;\nconst hasValidContact = isPhoneValid || isEmailValid;\n\n// lead_key строим только из валидного контакта\nconst leadKey = isEmailValid ? leadEmail : isPhoneValid ? leadPhone : '';\n\nlet status = 'new';\nlet validationError = '';\n\nif (!hasMessage) {\n  status = 'failed';\n  validationError = 'message is required';\n} else if (!hasValidContact) {\n  status = 'incomplete';\n  validationError = 'valid phone or email is required';\n}\n\nconst leadId = `lead_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;\n\nreturn [\n  {\n    json: {\n      lead_id: leadId,\n      created_at: new Date().toISOString(),\n\n      lead_name: leadName,\n      lead_phone: isPhoneValid ? leadPhone : '',\n      lead_email: leadEmail,\n      lead_message: leadMessage,\n      source,\n\n      raw_phone: rawPhone,\n      raw_email: rawEmail,\n\n      is_phone_valid: isPhoneValid,\n      is_email_valid: isEmailValid,\n\n      lead_key: leadKey,\n      has_message: hasMessage,\n      has_contact: hasValidContact,\n\n      status,\n      validation_error: validationError,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        -112
      ],
      "id": "06ba7de4-6c14-4455-a962-13bf357fea07",
      "name": "Normalize + Validate Lead"
    },
    {
      "parameters": {
        "jsCode": "const originalLead = $('Prepare AI Input').item.json.original_lead;\n\nif (!originalLead) {\n  throw new Error('original_lead is missing from Prepare AI Input');\n}\n\nconst aiOutput = $input.item.json.output;\n\nconst fallbackParsed = {\n  lead_category: 'unknown',\n  priority: 'unknown',\n  lead_score: 0,\n  intent: 'ai_parse_failed',\n  summary: 'AI не смог корректно классифицировать заявку.',\n  recommended_action: 'Проверить заявку вручную и связаться с клиентом при необходимости.',\n  missing_info: [],\n};\n\nlet parsed = fallbackParsed;\nlet status = originalLead.status;\n\nif (!aiOutput) {\n  status = 'ai_failed';\n} else {\n  const raw = String(aiOutput).trim();\n\n  let cleanJsonString = raw\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n\n  const firstBrace = cleanJsonString.indexOf('{');\n  const lastBrace = cleanJsonString.lastIndexOf('}');\n\n  if (firstBrace !== -1 && lastBrace !== -1 && lastBrace > firstBrace) {\n    cleanJsonString = cleanJsonString.slice(firstBrace, lastBrace + 1);\n  }\n\n  try {\n    parsed = JSON.parse(cleanJsonString);\n  } catch (error) {\n    status = 'ai_failed';\n    parsed = fallbackParsed;\n  }\n}\n\nconst allowedCategories = [\n  'course_interest',\n  'consultation_request',\n  'pricing_question',\n  'support_question',\n  'partnership',\n  'spam_or_irrelevant',\n  'unknown',\n];\n\nconst allowedPriorities = ['hot', 'warm', 'cold', 'unknown'];\n\nlet leadCategory = allowedCategories.includes(parsed.lead_category)\n  ? parsed.lead_category\n  : 'unknown';\n\nlet priority = allowedPriorities.includes(parsed.priority)\n  ? parsed.priority\n  : 'unknown';\n\n// Lead score validation\nlet leadScore = Number(parsed.lead_score);\n\nif (Number.isNaN(leadScore)) {\n  if (priority === 'hot') {\n    leadScore = 85;\n  } else if (priority === 'warm') {\n    leadScore = 55;\n  } else if (priority === 'cold') {\n    leadScore = 20;\n  } else {\n    leadScore = 0;\n  }\n}\n\nleadScore = Math.round(Math.max(0, Math.min(100, leadScore)));\n\n// Если priority unknown, но score явно высокий/средний/низкий — можно восстановить priority\nif (priority === 'unknown' && leadScore > 0) {\n  if (leadScore >= 71) {\n    priority = 'hot';\n  } else if (leadScore >= 31) {\n    priority = 'warm';\n  } else {\n    priority = 'cold';\n  }\n}\n\n// Если score противоречит priority, приоритет важнее, но score мягко поправляем\nif (priority === 'hot' && leadScore < 71) {\n  leadScore = 85;\n}\n\nif (priority === 'warm' && (leadScore < 31 || leadScore > 70)) {\n  leadScore = 55;\n}\n\nif (priority === 'cold' && leadScore > 30) {\n  leadScore = 20;\n}\n\n// SLA calculation\nconst slaByPriority = {\n  hot: 15,\n  warm: 120,\n  cold: 1440,\n  unknown: 1440,\n};\n\nconst slaMinutes = slaByPriority[priority] || 1440;\nconst followUpDeadline = new Date(Date.now() + slaMinutes * 60 * 1000).toISOString();\n\nconst missingInfo = Array.isArray(parsed.missing_info)\n  ? parsed.missing_info\n  : [];\n\nreturn [\n  {\n    json: {\n      ...originalLead,\n\n      lead_category: leadCategory,\n      priority,\n      lead_score: leadScore,\n      sla_minutes: slaMinutes,\n      follow_up_deadline: followUpDeadline,\n\n      intent: String(parsed.intent || '').trim(),\n      summary: String(parsed.summary || '').trim(),\n      recommended_action: String(parsed.recommended_action || '').trim(),\n      missing_info: missingInfo\n        .map(item => String(item).trim())\n        .filter(Boolean)\n        .join(', '),\n\n      status,\n      is_duplicate: originalLead.is_duplicate,\n      duplicate_note: originalLead.duplicate_note || '',\n\n      processed_at: new Date().toISOString(),\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
