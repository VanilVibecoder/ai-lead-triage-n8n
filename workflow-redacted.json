    {
      "parameters": {
        "jsCode": "const lead = $json || {};\n\nconst priority = lead.priority || 'unknown';\nconst status = lead.status || 'unknown';\nconst category = lead.lead_category || 'unknown';\nconst score = Number.isFinite(Number(lead.lead_score)) ? Number(lead.lead_score) : 0;\nconst slaMinutes = Number.isFinite(Number(lead.sla_minutes)) ? Number(lead.sla_minutes) : 1440;\n\nconst isHot = priority === 'hot';\nconst isAiFailed = status === 'ai_failed';\nconst isDuplicate = lead.is_duplicate === true || lead.is_duplicate === 'true';\n\nlet title = '📩 Новая заявка';\n\nif (priority === 'hot') {\n  title = '🔥 Горячая заявка';\n} else if (priority === 'warm') {\n  title = '📩 Тёплая заявка';\n} else if (priority === 'cold') {\n  title = '🧊 Холодная заявка';\n}\n\nif (isAiFailed) {\n  title = '⚠️ Заявка требует ручной проверки';\n} else if (isDuplicate) {\n  if (priority === 'hot') {\n    title = '🔥 Повторная горячая заявка';\n  } else if (priority === 'warm') {\n    title = '📩 Повторная тёплая заявка';\n  } else if (priority === 'cold') {\n    title = '🧊 Повторная холодная заявка';\n  } else {\n    title = '📩 Повторная заявка';\n  }\n}\n\nconst contactParts = [];\n\nif (lead.lead_phone) {\n  contactParts.push(`Телефон: ${lead.lead_phone}`);\n}\n\nif (lead.lead_email) {\n  contactParts.push(`Email: ${lead.lead_email}`);\n}\n\nif (contactParts.length === 0) {\n  contactParts.push('Контакт: не указан');\n}\n\nconst duplicateText = isDuplicate\n  ? '\\n\\n⚠️ Возможный дубль заявки'\n  : '';\n\nlet slaText = '';\n\nif (slaMinutes < 60) {\n  slaText = `${slaMinutes} мин.`;\n} else if (slaMinutes === 60) {\n  slaText = '1 час';\n} else if (slaMinutes < 1440) {\n  slaText = `${Math.round(slaMinutes / 60)} ч.`;\n} else {\n  slaText = '24 ч.';\n}\n\nconst message = `${title}\n\nИмя: ${lead.lead_name || 'Не указано'}\n${contactParts.join('\\n')}\n\nКатегория: ${category}\nПриоритет: ${priority}\nScore: ${score}/100\nSLA: ответить в течение ${slaText}\nДедлайн: ${lead.follow_up_deadline || 'не указан'}\nСтатус: ${status}\n\nКратко:\n${lead.summary || 'Нет summary'}\n\nРекомендованное действие:\n${lead.recommended_action || 'Не указано'}\n\nИсточник: ${lead.source || 'unknown'}${duplicateText}`;\n\nreturn [\n  {\n    json: {\n      ...lead,\n      telegram_message: message,\n    },\n  },\n];"
      },
